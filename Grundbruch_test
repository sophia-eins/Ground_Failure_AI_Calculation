"""
Interaktives Skript: Fundamentabmessungen + Bodenprofil + angepasste Plots
(Nullpunkt in der unteren linken Ecke, GOK-Linie unterbrochen).
"""

import matplotlib.pyplot as plt
import matplotlib.patches as patches
import math

def get_input(prompt):
    """Float-Eingabe, ersetzt ',' durch '.'."""
    while True:
        val = input(f"{prompt}: ").strip().replace(',', '.')
        try:
            return float(val)
        except ValueError:
            print("⚠️ Ungültige Eingabe – bitte eine Zahl eingeben.")

def get_design_situation():
    """
    Fragt die EC7-Bemessungssituation ab (BS-P, BS-T oder BS-A/BS-E)
    und legt daraus die Teilbeiwerte fest:
      γ_G   – für ungünstige permanente Lasten
      γ_Q   – für ungünstige veränderliche Lasten
      γ_M   – für Bodenkennwerte (c', φ')
      γ_φ   – für den Reibungsbeiwert tan φ'
      γ_c   – für die Kohäsion c'
      γ_R   – für den Widerstand R (optional, z.B. Erdbau- bzw. Grundbruchwiderstand)
    """
    print("\n--- Bemessungssituation auswählen ---")
    print(" 1) BS-P  (permanent)")
    print(" 2) BS-T  (transient)")
    print(" 3) BS-A/BS-E  (accidental / earthquake)")
    while True:
        choice = input("Auswahl [1/2/3]: ").strip()
        if choice in ("1","2","3"):
            break
        print("Bitte 1, 2 oder 3 eingeben.")
    
    if choice == "1":
        bs = "BS-P"
        γ_G   = 1.35    # ungünstige permanente Last
        γ_Q   = 1.50    # ungünstige veränderliche Last
        γ_M   = 1.00    # Bodenkennwerte insgesamt
        γ_φ   = 1.00    # tan φ'
        γ_c   = 1.00    # c'
        γ_R   = 1.40    # Widerstandsfaktor (z.B. Erdwiderstand)
    elif choice == "2":
        bs = "BS-T"
        γ_G   = 1.20
        γ_Q   = 1.30
        γ_M   = 1.00
        γ_φ   = 1.00
        γ_c   = 1.00
        γ_R   = 1.30
    else:
        bs = "BS-A/BS-E"
        γ_G   = 1.10
        γ_Q   = 1.10
        γ_M   = 1.00
        γ_φ   = 1.00
        γ_c   = 1.00
        γ_R   = 1.20

    print(f"\nGewählte Situation: {bs}")
    print(f"→ γ_G  = {γ_G:.2f}   γ_Q  = {γ_Q:.2f}")
    print(f"→ γ_M  = {γ_M:.2f}   γ_φ  = {γ_φ:.2f}   γ_c = {γ_c:.2f}")
    print(f"→ γ_R  = {γ_R:.2f}\n")

    return bs, γ_G, γ_Q, γ_M, γ_φ, γ_c, γ_R


def get_foundation_dimensions():
    """Länge a, Breite b, Höhe h, Einbindetiefe d abfragen und validieren."""
    while True:
        print("\n--- Fundamentabmessungen ---")
        a = get_input("Länge a (m)")
        if a <= 0:
            print("❌ a muss > 0 sein."); continue

        b = get_input(f"Breite b (m, ≤ a = {a:.3f})")
        if b <= 0 or b > a:
            print(f"❌ b muss > 0 und ≤ a ({a:.3f}) sein."); continue

        h = get_input("Höhe h (m)")
        if h <= 0:
            print("❌ h muss > 0 sein."); continue

        d = get_input(f"Einbindetiefe d (m, ≤ h = {h:.3f})")
        if d <= 0 or d > h:
            print(f"❌ d muss > 0 und ≤ h ({h:.3f}) sein."); continue

        return a, b, h, d

def get_soil_profile():
    """
    1– oder 2-schichtiger Bodenaufbau abfragen:
      • Bezeichnung, φ, γ, c
      • bei 2 Schichten: Tiefe UK Schicht 1 unter GOK
    GW-Abfrage + Tiefe unter GOK → γ_w = 10 kN/m³
    Auftriebsbereinigte Einheitdichte γ' = γ – γ_w, wenn GW in/über
    der Schicht liegt.
    """
    # Schichtanzahl
    while True:
        n = input("\nAnzahl der Bodenschichten (1 oder 2): ").strip()
        if n in ('1','2'):
            n = int(n); break
        print("Bitte 1 oder 2 eingeben.")

    layers = []
    for i in range(1, n+1):
        name  = input(f"Bezeichnung Schicht {i}: ").strip() or f"Schicht_{i}"
        phi   = get_input(f"Winkel φ Schicht {i} (°)")
        gamma = get_input(f"Dichte γ Schicht {i} (kN/m³)")
        c     = get_input(f"Kohäsion c Schicht {i} (kN/m²)")
        bottom = None
        if n == 2 and i == 1:
            bottom = get_input("Tiefe UK Schicht 1 unter GOK (m)")
        layers.append({
            "name":   name,
            "phi":    phi,
            "gamma":  gamma,
            "c":      c,
            "bottom": bottom
        })

    # Grundwasser
    gw = input("\nIst Grundwasser vorhanden? (j/n): ").strip().lower()
    if gw == 'j':
        z_gw    = get_input("Tiefe GW-Spiegel unter GOK (m)")
        gamma_w = 10.0
    else:
        z_gw    = None
        gamma_w = 0.0

    # Auftriebsbereinigte Einheitdichte
    for idx, layer in enumerate(layers):
        top       = 0.0 if idx == 0 else layers[idx-1]["bottom"]
        bottom_fl = layer["bottom"] or float('inf')

        if z_gw is None or z_gw >= bottom_fl:
            layer["gamma_prime"] = layer["gamma"]
        else:
            layer["gamma_prime"] = layer["gamma"] - gamma_w

    return layers, z_gw, gamma_w

def get_loads():
    """
    Abfrage der charakteristischen Lasten:
      • Ständige Last Vg,k (kN) – verpflichtend
      • Veränderliche Last Qk (kN) – optional
    """
    Vgk = get_input("Charakteristische ständige Last Vg,k  (kN)")
    var = input("Tritt eine veränderliche Last auf? (j/n): ").strip().lower()
    if var == 'j':
        Qk = get_input("Charakteristische veränderliche Last Qk (kN)")
    else:
        Qk = 0.0
    return Vgk, Qk

def plot_foundation(a, b, h, d, layers, z_gw, Vgk, Qk):
    """Grundriss unverändert, Seitenansicht mit Boden, GOK, GW, Bodenkennwerten und Lastpfeil."""
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 12))
    fig.subplots_adjust(hspace=0.4)

    # ——— 1) Grundriss ———
    rect1 = patches.Rectangle((0, 0), a, b,
                              facecolor='lightgray', edgecolor='black',
                              hatch='xx', zorder=2)
    ax1.add_patch(rect1)
    ax1.plot(0, 0, 'ko', zorder=3)
    ax1.annotate('', xy=(a, -0.02*b), xytext=(0, -0.02*b),
                 arrowprops=dict(arrowstyle='<->'))
    ax1.text(a/2, -0.05*b, 'a', ha='center', va='top')
    ax1.annotate('', xy=(-0.02*a, b), xytext=(-0.02*a, 0),
                 arrowprops=dict(arrowstyle='<->'))
    ax1.text(-0.05*a, b/2, 'b', rotation=90, ha='right', va='center')
    ax1.set_aspect('equal','box')
    ax1.set_xlim(-0.1*a, 1.1*a)
    ax1.set_ylim(-0.1*b, 1.1*b)
    ax1.set_title('Grundriss')
    ax1.set_xlabel('Länge (m)')
    ax1.set_ylabel('Breite (m)')

    # ——— 2) Seitenansicht mit Bodenschichten ———
    y_bot = -d
    y_top = h - d

    # Gesamtdarstellungstiefe
    if len(layers) == 2:
        depth1  = layers[0]['bottom']
        bottom2 = depth1 + 8.0
    else:
        depth1  = None
        bottom2 = 8.0

    x_min, x_max = -b, 2*b
    y_min = -bottom2
    # etwas mehr Platz oben: bisher y_max, jetzt +5
    y_max = max(y_top, 0) + 0.1*(bottom2 + max(y_top,0)) + 5.0

    # Abstand vom linken Rand für Boden-Text
    x_text = x_min + 0.02 * (x_max - x_min)

    # — Bodenschichten —  
    if len(layers) == 1:
        # Eine Schicht
        soil = patches.Rectangle((x_min, y_min),
                                 x_max - x_min,
                                 -y_min,
                                 facecolor='khaki', edgecolor='none', zorder=0)
        ax2.add_patch(soil)
        # Beschriftung linksbündig in der Schicht
        mid_y = y_min / 2
        L = layers[0]
        text = (
            f"{L['name']}\n"
            f"φ = {L['phi']:.1f}°\n"
            f"c = {L['c']:.2f} kN/m²\n"
            f"γ/γ′ = {L['gamma']:.2f}/{L['gamma_prime']:.2f}"
        )
        ax2.text(x_text, mid_y, text,
                 ha='left', va='center', color='black', zorder=1)

    else:
        # Obere Schicht
        soil1 = patches.Rectangle((x_min, -depth1),
                                  x_max - x_min,
                                  depth1,
                                  facecolor='khaki', edgecolor='none', zorder=0)
        ax2.add_patch(soil1)
        # Untere Schicht
        soil2 = patches.Rectangle((x_min, -bottom2),
                                  x_max - x_min,
                                  bottom2 - depth1,
                                  facecolor='lightgreen', edgecolor='none', zorder=0)
        ax2.add_patch(soil2)

        # Beschriftung obere Schicht
        L1 = layers[0]
        mid1 = -depth1 / 2
        text1 = (
            f"{L1['name']}\n"
            f"φ = {L1['phi']:.1f}°\n"
            f"c = {L1['c']:.2f} kN/m²\n"
            f"γ/γ′ = {L1['gamma']:.2f}/{L1['gamma_prime']:.2f}"
        )
        ax2.text(x_text, mid1, text1,
                 ha='left', va='center', color='black', zorder=1)

        # Beschriftung untere Schicht
        L2 = layers[1]
        mid2 = -(depth1 + (bottom2-depth1)/2)
        text2 = (
            f"{L2['name']}\n"
            f"φ = {L2['phi']:.1f}°\n"
            f"c = {L2['c']:.2f} kN/m²\n"
            f"γ/γ′ = {L2['gamma']:.2f}/{L2['gamma_prime']:.2f}"
        )
        ax2.text(x_text, mid2, text2,
                 ha='left', va='center', color='black', zorder=1)

    # — GOK-Linie bei y=0 —  
    ax2.hlines(0, x_min, x_max, colors='black', linewidth=1.5, zorder=2)
    ax2.text(x_max, 0, ' GOK', va='bottom', ha='left', color='black', zorder=2)

    # — Fundamentblock —  
    fund = patches.Rectangle((0, y_bot), b, h,
                             facecolor='lightgray', edgecolor='black',
                             hatch='xx', zorder=3)
    ax2.add_patch(fund)
    ax2.plot(0, y_bot, 'ko', zorder=4)

    # — GW-Linie (falls vorhanden) —  
    if z_gw is not None:
        y_gw = -z_gw
        ax2.hlines(y_gw, x_min, x_max,
                   colors='blue', linewidth=2, zorder=5)
        ax2.text(x_max, y_gw, ' GW', va='bottom', ha='left',
                 color='blue', zorder=5)

    # — Lastpfeil —  
    x_load         = b / 2
    # Pfeilspitze an der Fundament-Unterkante
    y_arrow_bottom = y_bot
    # Pfeilkopf deutlich unterhalb der Plot-Oberkante, z.B. 5 Einheiten über y_max-5
    y_arrow_top    = y_max - 0.5

    # Zeichne Pfeil von y_arrow_top nach y_arrow_bottom
    ax2.annotate(
        '',
        xy=(x_load, y_arrow_bottom),
        xytext=(x_load, y_arrow_top),
        arrowprops=dict(arrowstyle='->', color='red', lw=2),
        zorder=6
    )

    # Beschriftung rechts neben der Pfeilmitte
    mid_y_arrow = (y_arrow_top + y_arrow_bottom) / 2
    x_offset    = 0.02 * (x_max - x_min)
    load_text = f"Vg,k = {Vgk:.2f} kN"
    if Qk > 0:
        load_text += f"\nQk = {Qk:.2f} kN"
    ax2.text(
        x_load + x_offset,
        mid_y_arrow,
        load_text,
        ha='left', va='center',
        color='red', zorder=6
    )
    # Beschriftung rechts neben dem Pfeil
    mid_y_arrow = (y_arrow_top + y_arrow_bottom) / 2
    x_offset    = 0.02 * (x_max - x_min)
    load_text = f"Vg,k = {Vgk:.2f} kN"
    if Qk > 0:
        load_text += f"\nQk = {Qk:.2f} kN"
    ax2.text(x_load + x_offset, mid_y_arrow, load_text,
             ha='left', va='center', color='red', zorder=6)

    # — Achsen und Titel —  
    ax2.set_aspect('equal','box')
    ax2.set_xlim(x_min, x_max)
    ax2.set_ylim(y_min, y_max)
    ax2.set_title('Seitenansicht')
    ax2.set_xlabel('Breite (m)')
    ax2.set_ylabel('Tiefe (m)')

    plt.show()



def main():

    #  Bemessungssituation + Teilbeiwerte
    bs, γ_G, γ_Q, γ_M, γ_φ, γ_c, γ_R = get_design_situation()

    # Fundament
    a, b, h, d = get_foundation_dimensions()
    print(f"\nFundament: a={a:.3f} m, b={b:.3f} m, h={h:.3f} m, d={d:.3f} m")

    # Bodenprofil
    layers, z_gw, gamma_w = get_soil_profile()
    print("\n--- Bodenprofil ---")
    for i, L in enumerate(layers, start=1):
        bot = f"bis {L['bottom']:.3f} m" if L['bottom'] is not None else "bis ∞"
        print(
            f"Schicht {i} (“{L['name']}”) {bot}: "
            f"φ={L['phi']:.1f}°, γ={L['gamma']:.2f}, c={L['c']:.2f}, γ'={L['gamma_prime']:.2f}"
        )
    if z_gw is not None:
        print(f"GW bei z={z_gw:.3f} m unter GOK (γ_w={gamma_w:.1f})")

    #  Lasten definieren
    Vgk, Qk = get_loads()

    # Ausgabe
    print("\n--- Definierte Lasten ---")
    print(f"Ständige Last Vg,k       = {Vgk:.2f} kN")
    if Qk > 0:
        print(f"Veränderliche Last Qk    = {Qk:.2f} kN")
    else:
        print("Keine veränderliche Last definiert.")

    # 4) Bemessungswert der vertikalen Last (kein Exzentrizität)
    V_ed = γ_G * Vgk + γ_Q * Qk
    print(f"Bemessungswert der Vertikallast V_ed = {V_ed:.2f} kN\n")


    # Plots
    plot_foundation(a, b, h, d, layers, z_gw, Vgk, Qk)

if __name__ == "__main__":
    main()
